{
  "name": "zombie",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Assets": {
        "$path": "assets/Assets.rbxm"
      },
      "rbxts_include": {
        "$path": "ui/include",
        "node_modules": {
          "$className": "Folder",
          "@rbxts": {
            "$path": "ui/node_modules/@rbxts"
          },
          "@rbxts-js": {
            "$path": "ui/node_modules/@rbxts-js"
          }
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/game/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/game/client"
        },
        "UI": {
          "$path": "ui/out"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
